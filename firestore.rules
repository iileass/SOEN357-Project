rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────
    // Anyone can read user profiles (needed for member lookup by email).
    // Only the owner can write their own profile.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // ── Projects ────────────────────────────────────────────
      // Any authenticated user can READ project data (needed for shared project access).
      // Only the project owner can WRITE.
      match /projects/{projectId} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;

        // ── Tasks ──────────────────────────────────────────────
        match /tasks/{taskId} {
          allow read:  if request.auth != null;
          allow write: if request.auth != null && request.auth.uid == userId;
        }

        // ── Milestones ─────────────────────────────────────────
        match /milestones/{milestoneId} {
          allow read:  if request.auth != null;
          allow write: if request.auth != null && request.auth.uid == userId;

          match /tasks/{taskId} {
            allow read:  if request.auth != null;
            allow write: if request.auth != null && request.auth.uid == userId;
          }
        }

        // ── Members ────────────────────────────────────────────
        match /members/{memberId} {
          allow read:  if request.auth != null;
          allow write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // ── memberOf (back-references to projects where user is a member) ──
      // Read: only the user themselves.
      // Write: any authenticated user — project owners write these on behalf of members they add.
      match /memberOf/{docId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null;
      }
    }
  }
}
